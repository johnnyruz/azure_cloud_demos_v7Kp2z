#!/usr/bin/env sh

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File .githooks/pre-commit.ps1
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File .githooks/pre-commit.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File .githooks/pre-commit.ps1
else
  echo "PowerShell was not found. Cannot run the pre-commit secret scan."
  echo "Install PowerShell or run .githooks/pre-commit.ps1 manually before committing."
  exit 1
fi
